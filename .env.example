# Copy to backend/.env for local runs (optional)

DATABASE_URL=sqlite:///./nutrivoice.db
JWT_SECRET=replace-with-long-random-string

# Groq: meal parsing from transcript → structured JSON (set MOCK_AI=false)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# SpeechRecognition uses Google's free web API (needs internet).
# WebM decoding uses ffmpeg (brew install ffmpeg) or the bundled binary from imageio-ffmpeg.
SPEECH_RECOGNITION_LANGUAGE=en-US

# MOCK_WHISPER=true  → skip STT, use MOCK_WHISPER_TEXT (tests).
# MOCK_AI=true       → skip Groq; use built-in food table parser.
MOCK_WHISPER=false
MOCK_AI=false
